# ModelBest / OpenAI-compatible endpoint.
# Copy this file to .env, then put your real API key in .env only.
LLM_BASE_URL=https://llm-center.modelbest.cn/llm/v1
LLM_API_KEY=replace-with-your-local-api-key
LLM_MODEL=deepseek-v3.2
# Optional channel ID, e.g. DEEPSEEK_ztpuix or DEEPSEEK_sq37t2.
LLM_PROVIDER_ID=
LLM_ENABLE_THINKING=false
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=120

# Local runtime paths. Keep these unless you move the project.
BP_DB_PATH=data/bp_screener.sqlite
BP_INBOX_DIR=data/inbox

# Optional local OCR for scanned PDFs.
# Requires Tesseract OCR installed on the machine.
PDF_TEXT_ENGINE=pymupdf
OCR_ENABLED=true
OCR_LANG=eng+chi_sim
OCR_MIN_PAGE_CHARS=80
OCR_MIN_DOCUMENT_CHARS=800
OCR_MAX_PAGES=25
OCR_DPI=180
# Example on Windows:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
# Optional project-local language data directory.
OCR_TESSDATA_DIR=data/tessdata

# Lightweight RAG speed controls.
RAG_KEYWORD_PREFILTER_LIMIT=80
RAG_SEMANTIC_MAX_ROWS=20000
RAG_QA_CACHE_ENABLED=true

# Optional Notion integration.
# Create a Notion internal integration, share the parent page with it,
# then run: python scripts\notion_sync.py setup
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_PROJECTS_DATABASE_ID=
NOTION_REVIEWS_DATABASE_ID=
NOTION_COMMITTEE_DATABASE_ID=
NOTION_ACTIVITY_DATABASE_ID=
